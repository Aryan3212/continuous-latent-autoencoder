# Copy this file to .env (gitignored) and fill in only the values you need.
# Keep real credentials out of tracked files.

# Read access to private Hugging Face datasets or model repositories.
HF_TOKEN=

# Optional experiment logging.
WANDB_API_KEY=

# Data preparation only.
KAGGLE_USERNAME=
KAGGLE_KEY=
MDC_API_KEY=

# Optional project overrides.
# HF_DATASET_REPO=your-account/your-dataset
# HF_MODEL_REPO=your-account/your-model
