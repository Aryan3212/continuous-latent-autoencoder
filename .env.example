# Copy to .env (gitignored) and fill in. setup.sh sources this into the
# environment; the housekeeping CLI and train.py read the vars directly (no
# generated creds file). Plain shell syntax: KEY=value, quote values containing
# spaces. Already-exported env vars override these.

# Required on a training VM: read access to the packed dataset repo.
HF_TOKEN=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

# Optional: live W&B logging. Unset -> setup.sh falls back to WANDB_MODE=offline.
WANDB_API_KEY=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

# Prep-instance only (`make pack-and-push` / `download`); not needed to train:
#   - KAGGLE_*   -> regspeech12 (Kaggle-hosted)
#   - MDC_API_KEY -> common_voice_bn (Mozilla Data Collective; Account -> Credentials)
KAGGLE_USERNAME=aryanrahman
KAGGLE_KEY=KGAT_2fad797e191d616ac212ccb2ca5d4416
MDC_API_KEY=

# Defaults usually fine; uncomment to override.
#HF_DATASET_REPO=aryanrahman/clae-bengali
#HF_MODEL_REPO=aryanrahman/clae-bengali-encoder
