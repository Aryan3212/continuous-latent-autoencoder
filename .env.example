# Copy to .env (gitignored) and fill in; setup.sh reads this and generates
# clae_data/_creds.py from it. Plain shell syntax: KEY=value, quote values
# containing spaces. Already-exported env vars override these.

# Required on a training VM: read access to the packed dataset repo.
HF_TOKEN=

# Optional: live W&B logging. Unset -> setup.sh falls back to WANDB_MODE=offline.
WANDB_API_KEY=

# Only needed on a prep instance running `make pack-and-push`
# (bengaliai_speech + regspeech12 come from Kaggle). Not needed for training.
KAGGLE_USERNAME=
KAGGLE_KEY=

# Defaults usually fine; uncomment to override.
#CLAE_HF_REPO=aryanrahman/clae-bengali
#CLAE_CKPT_REPO=aryanrahman/clae-bengali-encoder
#CLAE_DATA_ROOT=$HOME/data/clae
#CONFIG=configs/exp0.yaml
#TRAIN_EXTRA_ARGS="train.max_steps=30000"
