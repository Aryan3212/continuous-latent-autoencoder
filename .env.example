# Copy this file to .env (gitignored) and fill in only the values you need.
# Keep real credentials out of tracked files.

# Optional for public HF data; required for gated data and publishing.
HF_TOKEN=

# Optional experiment logging. Without a key, setup.sh uses offline mode.
WANDB_API_KEY=
# WANDB_PROJECT=continuous-latent-autoencoder

# Data preparation only.
KAGGLE_USERNAME=
KAGGLE_KEY=
MDC_API_KEY=
# MDC_API_BASE=https://mozilladatacollective.com/api

# Optional project overrides.
# HF_DATASET_REPO=your-account/your-dataset
# HF_MODEL_REPO=your-account/your-model
# HOUSEKEEPING_WORKERS=4
