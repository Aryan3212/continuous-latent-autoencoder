# Copy to .env (gitignored) if migrating from clae_data/_creds.py to env vars.
# By default the project uses clae_data/_creds.py — these are only needed if
# you delete that file in favor of env-driven creds.
HF_TOKEN=
KAGGLE_USERNAME=
KAGGLE_KEY=
WANDB_API_KEY=
CLAE_HF_REPO=aryanrahman/clae-bengali
CLAE_CKPT_REPO=aryanrahman/clae-bengali-encoder
CLAE_DATA_ROOT=/data/clae
